# ShipSignal — local dev environment (LocalStack + local Postgres).
#
# Copy this file to `local/dev-env` and fill in the secrets, then run the bootstrap:
#   PowerShell:  pwsh local/bootstrap.ps1
#   bash/WSL:    bash local/bootstrap.sh
#
# `local/dev-env` is git-ignored. NEVER commit real secrets.
# This is NOT a `.env` file on purpose: `.env*` is a harness-protected path, so the
# bootstrap loads THIS file into the process env instead.

# ----------------------------------------------------------------------------------
# AWS / LocalStack
# ----------------------------------------------------------------------------------
# boto3 (>=1.28) and the AWS SDKs honor AWS_ENDPOINT_URL globally, so every AWS call
# (S3, SNS, Bedrock) from the Python worker is routed to LocalStack with NO code change.
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1
# LocalStack ignores credential values but boto3 requires them to be present.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Two modes (see docs/local-dev.md "Quickstart"):
#   * DASHBOARD-ONLY (default, FREE): community LocalStack provides S3 + SNS. This is enough
#     to run and test the whole DASHBOARD end-to-end — seed demo data with the home page's
#     "Load sample release" button. Bedrock model calls are NOT available in this mode, which
#     only matters if you run the worker generation graphs locally.
#   * FULL (LocalStack Pro, PAID): adds emulated Bedrock + Guardrails for the worker graphs.
#     Set LOCALSTACK_IMAGE=localstack/localstack-pro:latest, add bedrock to LOCALSTACK_SERVICES,
#     and paste your token below (https://app.localstack.cloud -> Auth Token).
LOCALSTACK_IMAGE=localstack/localstack:latest
# secretsmanager (community) backs per-project GitHub credentials (Projects feature, migration
# 0030). The worker resolves a project's token from Secrets Manager at run time.
LOCALSTACK_SERVICES=s3,sns,secretsmanager
LOCALSTACK_AUTH_TOKEN=

# Optional LocalStack toggles (used by docker-compose):
LS_DEBUG=0
LS_PERSISTENCE=0

# ----------------------------------------------------------------------------------
# Database (Postgres on host port 5434, TLS on)
# ----------------------------------------------------------------------------------
POSTGRES_USER=shipsignal
POSTGRES_PASSWORD=shipsignal
POSTGRES_DB=shipsignal
# Plain libpq form — used by the Next.js app (pg) AND the Python worker (psycopg).
# The worker auto-appends sslmode=require; the app reads PGSSLMODE below.
# (Alembic needs the postgresql+psycopg:// form — the bootstrap derives it for you.)
DATABASE_URL=postgresql://shipsignal:shipsignal@localhost:5434/shipsignal
PGSSLMODE=require

# ----------------------------------------------------------------------------------
# S3 buckets (created in LocalStack by the bootstrap)
# ----------------------------------------------------------------------------------
EVIDENCE_BUCKET=shipsignal-evidence
MEDIA_BUCKET=shipsignal-media

# ----------------------------------------------------------------------------------
# Bedrock (LocalStack Pro)
# ----------------------------------------------------------------------------------
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
# A published Guardrail is MANDATORY in code (BedrockModelClient refuses to run
# without it). The bootstrap attempts to create one in LocalStack and prints the id;
# paste the result here. If LocalStack's Bedrock rejects guardrailConfig, see
# docs/local-dev.md "Bedrock caveats".
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=DRAFT

# ----------------------------------------------------------------------------------
# GitHub (real API — LocalStack cannot emulate this)
# ----------------------------------------------------------------------------------
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
GITHUB_WORKFLOW_FILE=release-run.yml
GITHUB_WORKFLOW_REF=main
# HMAC secret for the inbound GitHub webhook route (any random string locally).
GITHUB_WEBHOOK_SECRET=local-dev-webhook-secret
#
# Per-PROJECT GitHub credentials (Projects feature, migration 0030): a project may map to its OWN
# token held in AWS Secrets Manager — the DB stores only the secret NAME/ARN (never the token). The
# worker resolves it at run time; a run with no project falls back to GITHUB_TOKEN above.
#   Create a demo secret in LocalStack:
#     awslocal secretsmanager create-secret --name shipsignal/github/<project> \
#       --secret-string '<the-PAT>'        # (or '{"token":"<the-PAT>"}')
#   Then in /projects set the project's "GitHub secret reference" to that name (shipsignal/github/<project>).
# PROD: grant the worker's OIDC role (AWS_RELEASE_RUN_ROLE_ARN) secretsmanager:GetSecretValue scoped
# to arn:aws:secretsmanager:*:*:secret:shipsignal/github/* (least privilege).

# ----------------------------------------------------------------------------------
# ElevenLabs (real API — LocalStack cannot emulate this). Media graph only.
# ----------------------------------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
# Scratch dir for narration/video the worker writes before S3 upload (default /tmp
# does not exist on Windows — keep this repo-local).
MEDIA_WORK_DIR=./.localmedia

# ----------------------------------------------------------------------------------
# Publishing channels (Path B / Phases 3-4) — all OPTIONAL; safe defaults for local.
# ----------------------------------------------------------------------------------
# With no channel credentials, publishing runs as a DRY-RUN: the full approve->publish loop
# executes and the UI shows exactly what WOULD post, but nothing is sent. Ideal for local.
# PUBLISH_DRY_RUN=1 forces dry-run even if you later add real tokens.
PUBLISH_DRY_RUN=1
# 'manual' (default) or 'scheduled'. Use 'scheduled' to exercise approve-then-schedule + the
# "Schedule" controls on the Gate #2 / artifact pages and the Distribute "Scheduled posts" queue.
PUBLISH_MODE=scheduled
# Real channel tokens — leave empty to keep everything in dry-run.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID=
X_ACCESS_TOKEN=
# Shared secret guarding the scheduled-publish DRAIN endpoint (POST /api/internal/
# scheduled-publishes/run). Any random string locally; unset = drain returns 503 (off). To
# fire due posts locally, POST to that route with header: Authorization: Bearer <this value>.
SCHEDULED_PUBLISH_SECRET=local-dev-drain-secret

# ----------------------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------------------
DASHBOARD_BASE_URL=http://localhost:3000
# Gate #3 repo write mode: 'direct' (write checked-out tree) or 'pr' (branch + PR).
SKILL_PROMOTION_MODE=direct
